{
  "name": "nightlights-viirs",
  "title": "District-Level Nighttime Lights (VIIRS)",
  "description": "Annual district-level nighttime light statistics for 641 Indian districts (2012-2024), derived from NOAA VIIRS DNB satellite imagery. Includes mean, median, sum, min, max, standard deviation, and log-transformed radiance values.",
  "category": "remote-sensing",
  "level": "district",
  "coverage": {
    "spatial": "India — 641 districts, 35 states/UTs",
    "temporal": "2012–2024 (annual)",
    "admin_level": "district (Census 2011 boundaries)"
  },
  "sources": [
    {
      "name": "NOAA VIIRS DNB Monthly Composites",
      "url": "https://eogdata.mines.edu/products/vnl/",
      "authority": "NOAA / Earth Observation Group"
    },
    {
      "name": "DataMeet District Boundaries (Census 2011)",
      "url": "https://github.com/datameet/maps",
      "authority": "DataMeet community"
    },
    {
      "name": "india-district-nightlights-viirs pipeline",
      "url": "https://github.com/yashveeeeeer/india-district-nightlights-viirs",
      "authority": "yashveeeeeer"
    }
  ],
  "license": {
